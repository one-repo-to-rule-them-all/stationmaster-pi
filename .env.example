# stationmaster-pi — Raspberry Pi configuration
#
# Copy this to `.env` and fill in your values.
# bootstrap.py will prompt for anything left blank on first run.
# Generated passwords are written back to this file automatically.

# ─── NAS ──────────────────────────────────────────────────────────────────────
# UNC path to your WD MyCloud (or any SMB share).
# This is the share root that gets mounted at NAS_MOUNT_POINT.
NAS_UNC_PATH=//WDMYCLOUD/Public

# Linux mount point. Must match the path in /etc/fstab.
NAS_MOUNT_POINT=/mnt/nas

# NAS credentials. bootstrap.py writes /etc/stationmaster-nas.creds (chmod 600).
# Leave blank for anonymous/guest access.
NAS_USER=media
NAS_PASS=M3dia123!

# Media subdirectories under NAS_MOUNT_POINT.
# Your layout: /mnt/nas/Videos/<kind>
NAS_MOVIES_KIDS_DIR=Videos/Movies/Kids
NAS_MOVIES_ADULT_DIR=Videos/Movies/Adult
NAS_SHOWS_DIR=Videos/TV Shows
NAS_FITNESS_DIR=Videos/Fitness
NAS_STANDUP_DIR=Videos/Stand Up Comedy

# ─── Jellyfin ─────────────────────────────────────────────────────────────────
JELLYFIN_HOST=http://localhost:8096

# Admin account created during first-run wizard.
# Leave PASS blank to have bootstrap.py generate a strong one and write it
# back to this file.
JELLYFIN_ADMIN_USER=cmpe8803
JELLYFIN_ADMIN_PASS=

# Optional second admin user (auto-generated password if left blank).
# Leave USER blank to skip.
JELLYFIN_EXTRA_USER=
JELLYFIN_EXTRA_PASS=

# View-only "media" account for TV/phone clients.
# Leave JELLYFIN_MEDIA_USER blank to skip creation.
# Password defaults to "media123" if left blank (easy to type on a TV remote).
JELLYFIN_MEDIA_USER=media
JELLYFIN_MEDIA_PASS=media123

# ─── ErsatzTV ─────────────────────────────────────────────────────────────────
ETV_HOST=http://localhost:8409

# GitHub repo for ErsatzTV releases (ErsatzTV/legacy ships linux-arm64 binaries).
ETV_GITHUB_REPO=ErsatzTV/legacy

# Path to the ErsatzTV executable.
# Leave blank to use the default: /opt/ersatztv/ErsatzTV
# ETV_EXE_PATH=/opt/ersatztv/ErsatzTV

# Path to the ErsatzTV SQLite database.
# Leave blank to use the XDG default: ~/.local/share/ersatztv/ersatztv.sqlite3
# ETV_DB_PATH=

# LAN URL for ErsatzTV UI (used in diagnostic output so you can reach it
# from another machine). Leave blank to auto-detect the Pi's primary LAN IP.
# ERSATZTV_LAN=http://192.168.x.x:8409

# URL Jellyfin uses to fetch M3U/XMLTV from ErsatzTV.
# Default is localhost — keeps setup stable across DHCP rotations.
# Only override if JF and ETV are on different machines.
# JF_ETV_URL=http://localhost:8409

# Simultaneous stream cap. 4 prevents "stream limit reached" errors from
# clients that disconnect uncleanly.
# JF_TUNER_COUNT=4

# FFmpeg profile ID to attach to created channels.
# Default = 1 (first profile ErsatzTV creates on first run).
FFMPEG_PROFILE_ID=1

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=America/Chicago

# ─── Auto-channel generation ──────────────────────────────────────────────────
# AUTO_SHOWS_MIN  : every TV show with at least N episodes gets its own channel
# AUTO_MOVIES_MIN : every franchise with at least N films gets its own channel
# Leave at 0 / unset to use only the manual CHANNEL_DEFS in full_setup.py.
#
# AUTO_SHOWS_MIN=10
# AUTO_MOVIES_MIN=2
